#include <windows.h>

// 图标资源 (必须是第一个资源)
IDI_ICON1 ICON "gamepad-icon.ico"

// Windows应用清单 - 声明程序身份和用途
1 24 "app.manifest"

// 版本信息 - 增强版本以提高可信度
VS_VERSION_INFO VERSIONINFO
 FILEVERSION 1,0,0,0
 PRODUCTVERSION 1,0,0,0
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "Kezry"
            VALUE "FileDescription", "Gamepad Test Client - Legitimate gamepad gyroscope data reader for testing motion sensors"
            VALUE "FileVersion", "1.0.0.0"
            VALUE "InternalName", "gamepad-test-client"
            VALUE "LegalCopyright", "Copyright (C) 2025 Kezry. MIT License. Open Source: https://github.com/Kezry/gamepadtest-client"
            VALUE "LegalTrademarks", "Gamepad Test Client is an open source project for testing gamepad functionality"
            VALUE "OriginalFilename", "gamepad-test-client.exe"
            VALUE "ProductName", "Gamepad Test Client"
            VALUE "ProductVersion", "1.0.0.0"
            VALUE "PrivateBuild", "This is a legitimate gamepad testing tool. It reads HID device data for gaming controllers."
            VALUE "SpecialBuild", "Open source gamepad gyroscope testing utility"
        END
    END

    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
