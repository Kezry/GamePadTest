# ============================================================
# gamePad-tests-Pro-All .gitignore
# C++ Client (gamepad-tests-client) + Web App (gamepad-tests-pro)
# ============================================================

# ----- OS -----
.DS_Store
Thumbs.db

# ----- IDE -----
.vscode/
.idea/
*.swp
*.swo
*~

# ----- Logs -----
*.log

# ----- Temporary -----
*.tmp
*.temp
*.bak

# ============================================================
# C++ / CMake (gamepad-tests-client)
# ============================================================

# Build directories
gamepad-tests-client/build/
gamepad-tests-client/Build/
gamepad-tests-client/out/
gamepad-tests-client/cmake-build-*/

# Visual Studio
*.suo
*.user
*.vcxproj
*.vcxproj.filters
*.sln
.vs/

# Compiled files
*.o
*.obj
*.exe
*.dll
*.so
*.dylib
*.a
*.lib

# Keep the pre-compiled client executable
!gamepad-tests-client/client/gamepad-test-client.exe

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake
!**/CMakeLists.txt

# External dependencies (downloaded at build time)
gamepad-tests-client/external/

# ============================================================
# Node.js / React (gamepad-tests-pro)
# ============================================================

node_modules/
dist/
dist-ssr/
*.local

# Environment variables
.env
.env.local
.env.production
.env.*.local
